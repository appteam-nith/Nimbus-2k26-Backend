generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// EXISTING ENUMS
//////////////////////

enum ClubType {
  DEPARTMENTAL
  CORE
}

//////////////////////
// GAME ENUMS
//////////////////////

enum GameStatus {
  LOBBY
  DISCUSSION
  NIGHT
  VOTING
  REVEAL
  ENDED
}

enum GameWinner {
  MAFIA
  CITIZENS
}

enum GameRole {
  MAFIA
  MAFIA_HELPER
  HITMAN
  CITIZEN
  DOCTOR
  COP
  NURSE
  BOUNTY_HUNTER
  PROPHET
  REPORTER
}

enum PlayerStatus {
  ALIVE
  ELIMINATED
}

enum GameRoomSize {
  FIVE
  EIGHT
  TWELVE
}

enum VoteType {
  DAY_LYNCH
  MAFIA_TARGET
  DOC_SAVE
  COP_INVESTIGATE
  NURSE_ACTION
  HITMAN_TARGET
  BOUNTY_HUNTER_VIP
  BOUNTY_HUNTER_SHOT
  REPORTER_EXPOSE
}

//////////////////////
// USER
//////////////////////

model User {
  user_id    String   @id @default(uuid()) @db.Uuid
  google_id  String?  @unique
  full_name  String
  email      String   @unique
  created_at DateTime @default(now())

  game_players GamePlayer[]
  hosted_rooms GameRoom[]   @relation("RoomHost")
}

//////////////////////
// CLUB SYSTEM
//////////////////////

model CoreTeamMember {
  id         Int      @id @default(autoincrement())
  name       String
  role       String
  image_url  String?
  linkedin   String?
  created_at DateTime @default(now())
}

model Club {
  club_id    Int      @id @default(autoincrement())
  club_name  String   @unique
  club_type  ClubType @default(DEPARTMENTAL)
  department String?
  created_at DateTime @default(now())

  events   Event[]
  projects Project[]
}

model Project {
  project_id   Int      @id @default(autoincrement())
  project_name String
  description  String?
  image_url    String?
  created_at   DateTime @default(now())

  club_id Int
  club    Club @relation(fields: [club_id], references: [club_id], onDelete: Cascade)

  @@index([club_id])
}

model Event {
  event_id           Int      @id @default(autoincrement())
  event_name         String
  venue              String
  image_url          String?
  extra_details      Json?
  event_time         DateTime
  created_at         DateTime @default(now())

  organizing_club_id Int
  club               Club @relation(fields: [organizing_club_id], references: [club_id], onDelete: Cascade)

  @@index([event_time])
}

//////////////////////
// GAME ROOM
//////////////////////

model GameRoom {
  room_code String @id

  host_id String @db.Uuid
  host    User   @relation("RoomHost", fields: [host_id], references: [user_id], onDelete: Cascade)

  room_size GameRoomSize

  status GameStatus @default(LOBBY)
  round  Int        @default(0)

  phase_ends_at      DateTime?
  discussion_seconds Int       @default(30)

  eliminated_this_round String?
  winner                GameWinner?
  nurse_met_doctor      Boolean    @default(false)

  state_meta Json? @default("{}")

  created_at DateTime @default(now())

  players GamePlayer[]
  votes   GameVote[]

  @@index([status])
  @@index([status, room_size])
}

//////////////////////
// GAME PLAYER
//////////////////////

model GamePlayer {
  id String @id @default(cuid())

  room_code String
  user_id   String @db.Uuid

  role   GameRole?
  status PlayerStatus @default(ALIVE)

  joined_at DateTime @default(now())

  user User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  room GameRoom @relation(fields: [room_code], references: [room_code], onDelete: Cascade)

  votes_cast     GameVote[] @relation("VotesCast")
  votes_received GameVote[] @relation("VotesReceived")

  @@unique([room_code, user_id])
  @@index([room_code])
  @@index([room_code, status])
}

//////////////////////
// GAME VOTE
//////////////////////

model GameVote {
  id String @id @default(cuid())

  room_code String
  round     Int

  voter_id  String
  target_id String?

  vote_type   VoteType @default(DAY_LYNCH)
  target_meta Json?

  created_at DateTime @default(now())

  room   GameRoom    @relation(fields: [room_code], references: [room_code], onDelete: Cascade)
  voter  GamePlayer  @relation("VotesCast", fields: [voter_id], references: [id], onDelete: Cascade)
  target GamePlayer? @relation("VotesReceived", fields: [target_id], references: [id], onDelete: Cascade)

  @@unique([room_code, round, voter_id, vote_type])
  @@index([room_code, round])
  @@index([room_code, vote_type])
  @@index([voter_id])
  @@index([target_id])
}