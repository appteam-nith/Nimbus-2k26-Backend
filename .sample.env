DATABASE_URL='postgresql://user:password@host/db?sslmode=require'
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here

# ── Firebase Admin SDK ─────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → Service Accounts →
# "Generate new private key" → download the JSON and copy the values below.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as-is (with newlines as \n)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvAIBADANB...\n-----END PRIVATE KEY-----\n"

# ── Email (Nodemailer / Brevo) ─────────────────────────────────────────────────
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=2525
EMAIL_USER=your@smtp-brevo.com
EMAIL_PASS=your_smtp_password