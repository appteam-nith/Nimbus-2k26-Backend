DATABASE_URL='db_connection_string_here'
NODE_ENV=development

# Clerk — get keys from https://dashboard.clerk.com → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# authkey.io — get your key from https://console.authkey.io (used for SMS/OTP if needed)
AUTHKEY=your_authkey_here

# SMTP credentials used by the email OTP sender
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
EMAIL_USER=your_smtp_username_here
EMAIL_PASS=your_smtp_password_here
EMAIL_FROM=verified-sender@example.com
REQUIRE_EMAIL_VERIFICATION_OTP=true

# Frontend base URL
FRONTEND_URL=http://localhost:3000
